.container {
  padding: 20rpx 30rpx;
  background: #f5f6fa;
  min-height: 100vh;
}

.date-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.arrow {
  font-size: 48rpx;
  color: #333;
  padding: 0 20rpx;
}

.date-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
}

.input-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.input-area {
  width: 100%;
  height: 160rpx;
  font-size: 30rpx;
  color: #333;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.create-btn {
  flex: 1;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 12rpx;
  line-height: 2.4;
  margin: 0;
}

.create-btn::after {
  border: none;
}

.image-btn {
  width: 200rpx;
  background: #1989fa;
  color: #fff;
  font-size: 30rpx;
  border-radius: 12rpx;
  line-height: 2.4;
  margin: 0;
  padding: 0;
}

.image-btn::after {
  border: none;
}

.schedule-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.schedule-item {
  display: flex;
  align-items: flex-start;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 24rpx;
}

.time-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
  margin-right: 24rpx;
}

.time-start {
  font-size: 32rpx;
  font-weight: 600;
  color: #07c160;
}

.time-end {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.content-box {
  flex: 1;
}

.title {
  font-size: 30rpx;
  color: #222;
  font-weight: 500;
  line-height: 1.4;
}

.desc {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
  line-height: 1.4;
}

.delete-btn {
  font-size: 26rpx;
  color: #ff4d4f;
  padding: 10rpx 16rpx;
}

.empty-tip {
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 60rpx 0;
}
