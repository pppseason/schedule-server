.container {
  padding: 20rpx 30rpx;
  background: #f5f6fa;
  min-height: 100vh;
}

.month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.arrow {
  font-size: 48rpx;
  color: #333;
  padding: 0 20rpx;
}

.month-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
}

.weekdays {
  display: flex;
  background: #fff;
  border-radius: 16rpx 16rpx 0 0;
  padding: 20rpx 0 10rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  border-radius: 0 0 16rpx 16rpx;
  padding-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.day-cell {
  width: 14.28%;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
}

.day-cell.empty {
  background: transparent;
}

.day-cell.today .day-num {
  background: #07c160;
  color: #fff;
  border-radius: 50%;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
}

.day-num {
  font-size: 30rpx;
  color: #333;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #ff4d4f;
  border-radius: 50%;
  margin-top: 8rpx;
}

.tip {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-top: 30rpx;
}
